# Von install-elektron-stack.sh generierte Secrets -- NIE committen. Die
# zugehörigen Vorlagen ohne echte Werte (elektron-net-ppool/.env.example,
# elektron-net-faucet/.env.example, elektron-net/bitcoin.conf.example)
# bleiben bewusst getrackt und stehen als Referenz im Repo.
elektron-net-ppool/.env
elektron-net-faucet/.env
.env

# Wird vom Skript mit dem echten rpcauth-Hash überschrieben (Hash, nicht
# Klartext-Passwort -- aber trotzdem besser nicht committen).
elektron-net/bitcoin.conf

# Laufzeitdaten (Blockchain, Wallets, DB, Faucet-Config) -- entstehen erst
# auf dem Server durch die volumes-Mounts in docker-compose.yml.
data/

# Upstream-Quellcode, den clone_or_skip() bei jedem Lauf frisch von GitHub
# nachlädt -- gehört nicht in dieses schlanke Deploy-Repo. Falls du ihn
# doch mal aus Versehen committest, hier ausschließen:
elektron-net-ppool-ui/

# Deine ausgefüllte Config-Datei für install-elektron-stack.sh (--config) --
# enthält reale Domains/IPs und ggf. hCaptcha-Keys. Nur elektron-stack.conf.example
# (ohne echte Werte) gehört ins Repo.
elektron-stack.conf

