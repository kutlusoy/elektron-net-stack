# Copy this file's content into the REAL elektron-net-ppool/.env after
# `git clone`. Values below assume the master docker-compose.yml in this
# repo, where the node is reachable by its Compose service name.

# "elektron-net" = Compose service name of the node, resolvable on the
# shared "backend" network -- NOT host.docker.internal (that's only for a
# node running natively outside Docker).
ELEKTRON_RPC_URL=http://elektron-net

# Must match the rpcauth line you generated for elektron-net/bitcoin.conf.
ELEKTRON_RPC_USER=elektron_svc
ELEKTRON_RPC_PASSWORD=REPLACE_WITH_THE_PLAINTEXT_PASSWORD_FROM_RPCAUTH_PY
ELEKTRON_RPC_PORT=8332
ELEKTRON_RPC_TIMEOUT=10000

ELEKTRON_ZMQ_HOST=tcp://elektron-net:28332

API_PORT=3334
STRATUM_PORT=3333
STRATUM_MAX_CONNECTIONS_PER_LISTENER=10000

JOB_REFRESH_INTERVAL_MS=30000
DIFFICULTY_CHECK_INTERVAL_MS=60000

NETWORK=mainnet
API_SECURE=false
POOL_IDENTIFIER="Elektron-PPLNS-Pool"

HOBBY_MINER_USER_AGENTS=NerdMiner,NerdminerV2,nerdminer,NerdAxe,NerdQAxe
HOBBY_MINER_DIFFICULTY=0.001

DIAGNOSTIC_SHARE_LOGGING_MODES=

# =====================================================================
# PPLNS settings -- tune these before going live, see the ppool README
# =====================================================================

# REQUIRED. Create a dedicated wallet + address on the node first:
#   docker compose exec elektron-net elektron-cli createwallet "pool"
#   docker compose exec elektron-net elektron-cli -rpcwallet=pool getnewaddress "" bech32
POOL_WALLET_ADDRESS=

PPLNS_WINDOW_MINUTES=90
POOL_FEE_PERCENT=1.0
MIN_PAYOUT_THRESHOLD_SATS=100000
PAYOUT_INTERVAL_MINUTES=60
PAYOUT_CONFIRMATIONS_REQUIRED=1

# Keep this TRUE until you've verified payouts look correct (see ppool
# README "Verification before going live"). Flip to false only after that.
PAYOUT_DRY_RUN=true

# Same server for now (single Hetzner box) -- falls back to ELEKTRON_RPC_*
# above when left unset, which is what we want here.
#WALLET_RPC_HOST=
#WALLET_RPC_PORT=
#WALLET_RPC_USER=
#WALLET_RPC_PASSWORD=

# Only needed if the node ever loads more than one wallet at once.
WALLET_RPC_WALLET_NAME=pool

# Set this if you encrypt the pool wallet (recommended before real payouts).
#WALLET_PASSPHRASE=
#WALLET_UNLOCK_SECONDS=60

# =====================================================================
# Miner account login (address-signature based, see ppool README)
# =====================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
