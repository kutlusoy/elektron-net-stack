# Copy this file's content into the REAL elektron-net-seeder/.env after
# `git clone` (or let install-elektron-stack.sh write it for you when you
# answer "yes" to the "Seeder installieren?" prompt / set INSTALL_SEEDER=true
# in elektron-stack.conf).
#
# The seeder is OPTIONAL and still in its testing phase -- it is not built
# or started by a plain `docker compose up -d` (see the "seeder" profile on
# its service in docker-compose.yml). See README "Seeder (optional,
# Testphase)" before enabling it, especially the DNS delegation SEEDER_HOST
# needs (a separate NS record, not just an A/AAAA record like NODE_DOMAIN).

SEEDER_HOST=seeder.elektron-net.org
SEEDER_NS=node1.elektron-net.org
SEEDER_MBOX=admin.elektron-net.org

SEEDER_DNS_PORT=53
SEEDER_BIND_ADDRESS=::
SEEDER_THREADS=96
SEEDER_DNS_THREADS=4

# Optional overrides -- left empty, the seeder already defaults to
# elektron-net's own P2P port (8333) and network magic, so these normally
# don't need to be touched:
SEEDER_P2P_PORT=
SEEDER_MAGIC=
SEEDER_MIN_HEIGHT=
SEEDER_TOR_PROXY=
SEEDER_IPV4_PROXY=
SEEDER_IPV6_PROXY=
SEEDER_TESTNET=false
SEEDER_WIPE_BAN=false
SEEDER_WIPE_IGNORE=false
# Comma-separated, no spaces:
SEEDER_EXTRA_SEEDS=
SEEDER_FILTERS=
