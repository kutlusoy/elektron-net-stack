# Copy this file's content into the REAL elektron-net-seeder/.env after
# `git clone` (or let install-elektron-stack.sh write it for you).
# OPTIONAL/testing -- see README "Seeder (optional, Testphase)", especially
# the NS delegation SEEDER_HOST needs (not just an A/AAAA record).

SEEDER_HOST=seeder.eleknet.org
SEEDER_NS=node1.elektron-net.org
SEEDER_MBOX=admin.eleknet.org

SEEDER_DNS_PORT=53
SEEDER_BIND_ADDRESS=::
SEEDER_THREADS=96
SEEDER_DNS_THREADS=4
SEEDER_MIN_HEIGHT=70000                # young chain -- below the seeder's built-in mainnet default of 350000

# Left empty, defaults to elektron-net's own P2P port (8333) and magic:
SEEDER_P2P_PORT=
SEEDER_MAGIC=
SEEDER_TOR_PROXY=
SEEDER_IPV4_PROXY=
SEEDER_IPV6_PROXY=
SEEDER_TESTNET=false
SEEDER_WIPE_BAN=false
SEEDER_WIPE_IGNORE=false
SEEDER_EXTRA_SEEDS=                    # comma-separated, no spaces
SEEDER_FILTERS=                        # comma-separated, no spaces
