# ============================================================
# Elektron Net node config -- node1.elektron-net.org (mainnet)
# Mounted read-only into the container at /data/bitcoin.conf
# ============================================================

server=1
listen=1
bind=0.0.0.0:8333

# Seed node: accept inbound P2P from anywhere.
maxconnections=125

# --- RPC ---
# Bind on all interfaces INSIDE the container, but 8332 is never published
# to the host (see docker-compose.yml) -- only reachable from sibling
# containers (elektron-ppool, elektron-faucet-app) on the "backend" network.
rpcbind=0.0.0.0
rpcallowip=172.16.0.0/12

# Generate with: python3 elektron-net/share/rpcauth/rpcauth.py elektron_svc
# then paste the resulting "rpcauth=..." line here (3 lines of output: the
# rpcauth= line, your plaintext password to give to ppool/faucet .env files,
# and a reminder). Do NOT commit the real value to git.
#rpcauth=elektron_svc:REPLACE_WITH_GENERATED_SALT$REPLACE_WITH_GENERATED_HASH

# --- ZMQ (optional, speeds up ppool's block-change detection) ---
zmqpubrawblock=tcp://0.0.0.0:28332
zmqpubrawtx=tcp://0.0.0.0:28333

# --- Wallet ---
# Needed so ppool's POOL_WALLET_ADDRESS and the faucet's hot wallet can live
# on this same node. Create/encrypt wallets after first start via
# `docker compose exec elektron-net elektron-cli createwallet ...`.
disablewallet=0

# Note: pruning is MANDATORY and automatic on Elektron Net (197,280-block
# depth) -- there is no -prune= setting to configure; it's ignored by design.
