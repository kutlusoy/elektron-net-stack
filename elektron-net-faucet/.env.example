# Copy this file's content into the REAL elektron-net-faucet/.env after
# `git clone`, then create a project-root symlink so docker compose can
# substitute ${FAUCET_DB_*} in docker-compose.yml too:
#   ln -s elektron-net-faucet/.env .env   (run from the stack's root dir)
#
# Reminder: this whole file is a FIRST-INSTALL-ONLY seed (see faucet
# README). After the first container start, use admin.php for everything.

FAUCET_PORT=8080

# ---- Database ----
FAUCET_DB_HOST=elektron-faucet-db
FAUCET_DB_PORT=3306
FAUCET_DB_NAME=elek_faucet
FAUCET_DB_USER=elek_faucet
FAUCET_DB_PASS=CHANGE_ME
FAUCET_DB_ROOT_PASS=CHANGE_ME_ROOT

# ---- Encryption key (secrets at rest) ----
#FAUCET_APP_KEY=

# ---- Admin account (created once, on first install only) ----
FAUCET_ADMIN_USER=admin
FAUCET_ADMIN_PASS=CHANGE_ME_MIN_10_CHARS

# ---- elektron-net node RPC ----
# "elektron-net" = Compose service name of the node container, reachable on
# the shared "backend" network -- NOT host.docker.internal, since the node
# runs in this same stack, not natively on the host.
FAUCET_RPC_HOST=http://elektron-net
FAUCET_RPC_PORT=8332
FAUCET_RPC_USER=elektron_svc
FAUCET_RPC_PASS=REPLACE_WITH_THE_PLAINTEXT_PASSWORD_FROM_RPCAUTH_PY

# Dedicated faucet wallet -- create on the node first:
#   docker compose exec elektron-net elektron-cli createwallet "faucet"
#   docker compose exec elektron-net elektron-cli -rpcwallet=faucet encryptwallet "..."
#   docker compose exec elektron-net elektron-cli -rpcwallet=faucet getnewaddress "" bech32
FAUCET_WALLET_NAME=faucet
FAUCET_WALLET_PASS=REPLACE_WITH_THE_ENCRYPTWALLET_PASSPHRASE

FAUCET_RPC_TLS_VERIFY=1
FAUCET_RPC_TLS_VERIFY_HOST=0

# ---- hCaptcha (strongly recommended) ----
FAUCET_HCAPTCHA_SITE=
FAUCET_HCAPTCHA_SECRET=

# ---- Faucet business settings ----
FAUCET_TITLE=Elektron Net Faucet
FAUCET_MESSAGE=Claim some free ELEK!
FAUCET_AMOUNT_ELEK=0.001
FAUCET_DAILY_BUDGET=1
FAUCET_HOURLY_BUDGET=0.1
FAUCET_PER_ADDR_COOLDOWN_H=24
FAUCET_PER_IP_COOLDOWN_H=1
FAUCET_SENDER_ADDR=
FAUCET_EXPLORER_URL=
FAUCET_DEFAULT_LANG=de

# Minutes between checks that RBF fee-bump any faucet payout still
# unconfirmed because the node's live mempoolminfee has risen above what it
# paid. Also editable later without a restart via Admin Panel -> Mempool &
# Fee Bumping.
FAUCET_FEE_BUMP_INTERVAL_MIN=10
